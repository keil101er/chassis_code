void ui_update_g(void)
{
    for (int i = 0; i < TOTAL_FIGURE; i++)
    {
        if (memcmp(&ui_g_now_figures[i], &ui_g_last_figures[i], sizeof(ui_g_now_figures[i])) != 0)
        {
            ui_g_dirty_figure[i] = ui_g_max_send_count[i];
            ui_g_last_figures[i] = ui_g_now_figures[i];
        }
    }

    for (int i = 0; i < TOTAL_STRING; i++)
    {
        if (memcmp(&ui_g_now_strings[i], &ui_g_last_strings[i], sizeof(ui_g_now_strings[i])) != 0)
        {
            ui_g_dirty_string[i] = ui_g_max_send_count[TOTAL_FIGURE + i];
            ui_g_last_strings[i] = ui_g_now_strings[i];
        }
    }

    ui_scan_and_send(ui_g_now_figures, ui_g_dirty_figure, ui_g_now_strings, ui_g_dirty_string,
                     TOTAL_FIGURE, TOTAL_STRING);
}

void ui_force_refresh_g(void)
{
    for (int i = 0; i < TOTAL_FIGURE; i++)
    {
        ui_g_dirty_figure[i] = ui_g_max_send_count[i];
    }

    for (int i = 0; i < TOTAL_STRING; i++)
    {
        ui_g_dirty_string[i] = ui_g_max_send_count[TOTAL_FIGURE + i];
    }

    ui_scan_and_send(ui_g_now_figures, ui_g_dirty_figure, ui_g_now_strings, ui_g_dirty_string,
                     TOTAL_FIGURE, TOTAL_STRING);
}

void ui_refresh_string_create_g(void)
{
    static uint8_t refresh_cursor = 0;
    uint32_t saved_operate_type = ui_g_now_strings[refresh_cursor].operate_type;

    ui_g_now_strings[refresh_cursor].operate_type = 1;
    ui_string_frame.option = ui_g_now_strings[refresh_cursor];
    ui_proc_string_frame(&ui_string_frame);
    print_message((const uint8_t *)&ui_string_frame, sizeof(ui_string_frame));
    ui_g_now_strings[refresh_cursor].operate_type = saved_operate_type;

    refresh_cursor++;
    if (refresh_cursor >= TOTAL_STRING)
    {
        refresh_cursor = 0;
    }
}


void ui_refresh_figure_create_g(void)
{
    static const uint8_t refresh_order[TOTAL_FIGURE] = {
        8, 7, 10, 11, 12, 9, 6, 3, 4, 5, 0, 13, 1, 2
    };
    static uint8_t refresh_cursor = 0;
    uint8_t figure_index = refresh_order[refresh_cursor];
    uint32_t saved_operate_type = ui_g_now_figures[figure_index].operate_type;

    ui_g_now_figures[figure_index].operate_type = 1;
    ui_1_frame.data[0] = ui_g_now_figures[figure_index];
    ui_proc_1_frame(&ui_1_frame);
    print_message((const uint8_t *)&ui_1_frame, sizeof(ui_1_frame));
    ui_g_now_figures[figure_index].operate_type = saved_operate_type;

    refresh_cursor++;
    if (refresh_cursor >= TOTAL_FIGURE)
    {
        refresh_cursor = 0;
    }
}


void ui_refresh_key_figure_create_g(void)
{
    static const uint8_t key_indices[] = {7, 8, 9, 10, 11, 12};

    for (uint32_t i = 0; i < sizeof(key_indices) / sizeof(key_indices[0]); i++)
    {
        ui_send_single_figure(&ui_g_now_figures[key_indices[i]], 1U);
    }
}
