        ui_g_now_figures[idx].figure_name[1] = (uint8_t)((idx >> 8) & 0xFFU);
        ui_g_now_figures[idx].figure_name[2] = (uint8_t)(idx & 0xFFU);
        ui_g_dirty_figure[idx] = ui_g_max_send_count[idx];
        ui_g_last_figures[idx] = ui_g_now_figures[idx];
    }

    for (uint32_t idx = 0; idx < TOTAL_STRING; idx++)
    {
        uint32_t name = idx + TOTAL_FIGURE;
        ui_g_now_strings[idx].figure_name[0] = (uint8_t)((name >> 16) & 0xFFU);
        ui_g_now_strings[idx].figure_name[1] = (uint8_t)((name >> 8) & 0xFFU);
        ui_g_now_strings[idx].figure_name[2] = (uint8_t)(name & 0xFFU);
        ui_g_dirty_string[idx] = ui_g_max_send_count[TOTAL_FIGURE + idx];
        ui_g_last_strings[idx] = ui_g_now_strings[idx];
    }

